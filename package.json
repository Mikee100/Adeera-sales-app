{
  "name": "saas-pos",
  "version": "1.0.0",
  "description": "Point of Sale application for SaaS Platform",
  "author": "Adeera",
  "main": "dist/main.js",
  "scripts": {
    "start": "electron dist/main.js",
    "dev": "concurrently -k \"npm run build:watch\" \"npm run dev:electron\"",
    "dev:electron": "wait-on dist/main.js dist/preload.js dist/index.html && set NODE_ENV=development&& nodemon",
    "build": "webpack --mode production",
    "build:watch": "webpack --mode development --watch",
    "rebuild": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps",
    "package": "electron-builder",
    "package:win": "electron-builder --win",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux",
    "deploy:updates": "powershell -Command \"Copy-Item release/latest.yml ../backend/uploads/pos-updates/ -Force; Copy-Item release/*.exe ../backend/uploads/pos-updates/ -Force\""
  },
  "dependencies": {
    "@types/lru-cache": "^7.10.9",
    "@types/pako": "^2.0.4",
    "axios": "^1.6.0",
    "electron-log": "^5.4.3",
    "electron-store": "^8.1.1",
    "electron-updater": "^6.8.3",
    "lru-cache": "^11.2.2",
    "pako": "^2.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-window": "^1.8.11",
    "serialport": "^12.0.0",
    "socket.io-client": "^4.7.2",
    "uuid": "^9.0.1",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@serialport/bindings-cpp": "^12.0.0",
    "@types/electron": "^1.6.12",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-window": "^1.8.8",
    "@types/uuid": "^9.0.1",
    "concurrently": "^8.2.0",
    "css-loader": "^6.8.1",
    "electron": "^25.0.0",
    "electron-builder": "^24.13.3",
    "html-webpack-plugin": "^5.5.3",
    "nodemon": "^3.1.10",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.2.2",
    "wait-on": "^7.0.1",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "build": {
    "appId": "com.saasplatform.pos",
    "productName": "SaaS POS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "publish": [
        {
          "provider": "generic",
          "url": "https://saas-business.duckdns.org/updates/pos/"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Adeera POS"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
